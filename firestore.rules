rules_version = '2';

// İki kişilik özel uygulama. Kayıt ekranı yok; hesaplar Firebase
// panelinden elle açılıyor. Bu yüzden "giriş yapmış olmak" yeterli
// güvenlik sınırıdır — sadece o iki hesap mesajlara erişebilir.
service cloud.firestore {
  match /databases/{database}/documents {
    match /mesajlar/{mesajId} {
      allow read, write: if request.auth != null;
    }
    // FCM token'ları: karşı tarafın token'ını okuyup bildirim göndermek için
    match /kullanicilar/{uid} {
      allow read, write: if request.auth != null;
    }
    // Görüntülü/sesli arama sinyalleşmesi (aramalar/aktif dokümanı)
    match /aramalar/{aramaId} {
      allow read, write: if request.auth != null;
    }
  }
}
